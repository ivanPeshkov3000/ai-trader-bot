NODE_ENV=development
LOG_LEVEL=info
BOT_MODE=paper
BROKER_ACCOUNT_ID=demo-account
MAX_POSITION_SIZE_RUB=100000
MAX_DAILY_LOSS_RUB=10000
SYMBOLS=SBER,GAZP,LKOH

# Параметры стратегии
SMA_FAST_PERIOD=10
SMA_SLOW_PERIOD=30
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
STRATEGY_MIN_SCORE=0.3
PRICE_HISTORY_LENGTH=200
